# ─────────────────────────────────────────────────────────────
# AGUAFLOW — Variables de entorno
# Copia este archivo a: backend/.env
# ─────────────────────────────────────────────────────────────

# Base de datos
DATABASE_URL="postgresql://aguaflow:aguaflow_secret@localhost:5433/aguaflow_db"

# Servidor
PORT=3002
NODE_ENV=development
FRONTEND_URL=http://localhost:5174

# Tokens de conectores (se rellenan por usuario en la UI)
# Estos son ejemplos — el usuario los introduce en el dashboard
GITHUB_TOKEN=ghp_tu_token_aqui
NOTION_TOKEN=secret_tu_token_aqui
LINEAR_API_KEY=lin_api_tu_key_aqui
SLACK_BOT_TOKEN=xoxb-tu-token-aqui
ASANA_TOKEN=tu_asana_token_aqui
